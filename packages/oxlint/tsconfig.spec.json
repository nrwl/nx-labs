{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "moduleResolution": "node10",
    "resolveJsonModule": true,
    "types": ["jest", "node"]
  },
  "include": [
    "jest.config.ts",
    "*.d.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts",
    "src/**/*.json"
  ]
}
